# Etsy API credentials (from developers.etsy.com)
ETSY_API_KEY=your_api_keystring_here
ETSY_SHARED_SECRET=your_shared_secret_here

# Etsy seller taxonomy category ID. Required before the first real publish:
# the uploader (src/publisher/uploader.py) refuses to create a listing without
# one. The orchestrator reads this env var first and falls back to
# etsy.taxonomy_id in config/config.yaml. Discover the right ID with
# scripts/explore_taxonomy.py (searches the taxonomy tree for e.g. "Planner").
ETSY_TAXONOMY_ID=

# Emergency kill switch for Etsy uploads. Setting this to false/0/no forces
# uploads OFF regardless of config. It can NEVER force uploads on -- enabling
# still requires etsy.upload_enabled: true in config/config.yaml plus valid
# API credentials (see src/pipeline/orchestrator.py::_etsy_upload_enabled).
ETSY_UPLOAD_ENABLED=false

# Database (used by library callers; dashboard/scheduler use config paths.database
# -- keep the two pointing at the same file)
DATABASE_URL=sqlite:///data/planner.db

# Logging
LOG_LEVEL=INFO
# Set to "json" for machine-readable JSON log lines; any other value (or unset)
# keeps the human-friendly console renderer (src/monitoring/logger.py).
LOG_FORMAT=

# Dashboard login. The dashboard binds to the LAN (config dashboard.host:
# 0.0.0.0) so any device on your WiFi can reach it. Set a password to require
# HTTP Basic Auth on every page (recommended -- the dashboard can publish to
# Etsy). Leave DASHBOARD_PASSWORD empty for no login (localhost only is fine).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
